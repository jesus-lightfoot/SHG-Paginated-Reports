			"Full_Month_Rooms_Stats_To_FCL_Weekdays", 'Revenue Metrics'[Full Month Rooms Stats To FCL Weekdays],
			"Full_Month_Rooms_Stats_To_FCL_Weekends", 'Revenue Metrics'[Full Month Rooms Stats To FCL Weekends],
			"Full_Month_Transient_Rooms_Stats_To_FCL", 'Revenue Metrics'[Full Month Transient Rooms Stats To FCL],
			"Full_Month_Business_Travel_Rooms_Stats_To_FCL", 'Revenue Metrics'[Full Month Business Travel Rooms Stats To FCL],
			"Full_Month_Group_Trevel_Rooms_Stats_To_FCL", 'Revenue Metrics'[Full Month Group Trevel Rooms Stats To FCL],
			"Full_Month_Rooms_Stats_To_FCL", 'Revenue Metrics'[Full Month Rooms Stats To FCL],
			"Full_Month_Rooms_ADR_To_FCL_Weekdays", 'Revenue Metrics'[Full Month Rooms ADR To FCL Weekdays],
			"Full_Month_Rooms_ADR_To_FCL_Weekends", 'Revenue Metrics'[Full Month Rooms ADR To FCL Weekends],
			"Full_Month_Transient_Rooms_ADR_To_FCL", 'Revenue Metrics'[Full Month Transient Rooms ADR To FCL],
			"Full_Month_Business_Travel_Rooms_ADR_To_FCL", 'Revenue Metrics'[Full Month Business Travel Rooms ADR To FCL],
			"Full_Month_Group_Travel_Rooms_ADR_To_FCL", 'Revenue Metrics'[Full Month Group Travel Rooms ADR To FCL],
			"Full_Month_Rooms_ADR_To_FCL", 'Revenue Metrics'[Full Month Rooms ADR To FCL],
			"Full_Month_Total_F_B_Outlets_Revenue_To_FCL", 'Revenue Metrics'[Full Month Total F&amp;B Outlets Revenue To FCL],
			"Full_Month_F_B_B_C_Revenue_To_FCL", 'Revenue Metrics'[Full Month F&amp;B B&amp;C Revenue To FCL],
			"Full_Month_Total_F_B_Revenue_To_FCL", 'Revenue Metrics'[Full Month Total F&amp;B Revenue To FCL],
                                                "Missed_FCL", 'Revenue Metrics'[Missed FCL]
		)

	VAR __DS0PrimaryWindowed = 
		TOPN(502, __DS0Core, [IsGrandTotalRowTotal], 0, 'DimProperty'[PropertyName], 1)

EVALUATE
	__DS0PrimaryWindowed

ORDER BY
	[IsGrandTotalRowTotal] DESC, 'DimProperty'[PropertyName]</Statement>
              <ParameterDefinitions>
                <ParameterDefinition>
                  <Name>ControlDate</Name>
                  <DefaultValues>
                    <DefaultValue>10-01-2024</DefaultValue>
