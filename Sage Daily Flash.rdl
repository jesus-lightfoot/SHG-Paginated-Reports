                  <BreakLocation>Start</BreakLocation>
                </PageBreak>
                <Filters>
                  <Filter>
                    <FilterExpression>=IIF(Array.IndexOf(split("Hilton Garden Inn Boulder,
Renaissance Atlanta Midtown Hotel,
Hotel Commonwealth Boston,
MilePost Zero,
Hotel Vandivort,
Marriott Napa Valley Hotel &amp; Spa,
Ritz Carlton Chicago,
Mercantile,Hilton Denver City Center,Hotel de la Poste,The Ann Savannah",","),
CStr(Fields!PropertyName.Value))&gt;-1,"Include","Exclude")</FilterExpression>
                    <Operator>NotEqual</Operator>
                    <FilterValues>
                      <FilterValue>="Include"</FilterValue>
                    </FilterValues>
                  </Filter>
                </Filters>
                <SortExpressions>
                  <SortExpression>
                    <Value>=iif(weekday(Parameters!ControlDate.Value) &gt; 4,
  iif(
	(Fields!WTD_Night_Audit_Completed.Value &gt;= 1) 
	And (Fields!Two_Days_Ago_Checkin_Percent.Value &gt;= 1) 
	And (Fields!Prior_Day_Schedule_Publish_Percent.Value &gt;= 1)
	AND (Fields!WTD_Forecast_Volume_Entry.Value &gt;= 1)
  , 1,0)
,
  iif(
  	(Fields!WTD_Night_Audit_Completed.Value &gt;= 1) 
	And (Fields!Two_Days_Ago_Checkin_Percent.Value &gt;= 1)
	AND (Fields!WTD_Forecast_Volume_Entry.Value &gt;= 1)
  ,1,0
  )
)</Value>
                    <Direction>Descending</Direction>
                  </SortExpression>
                  <SortExpression>
                    <Value>=iif(IsNothing(Fields!MTD_Earned_Hrs.Value),
0
,
iif(
(Fields!MTD_Earned_Hrs.Value &lt; = 1),
1,0)
)</Value>
                    <Direction>Descending</Direction>
                  </SortExpression>
                  <SortExpression>
                    <Value>=iif(IsNothing(Fields!WTD_Earned_Hrs.Value),
0
,
iif(
(Fields!WTD_Earned_Hrs.Value &lt; = 1),
1,0)
)</Value>
                    <Direction>Descending</Direction>
                  </SortExpression>
                  <SortExpression>
                    <Value>=IIF(IsNothing(Fields!MTD_Earned_Hrs.Value),999999,Fields!MTD_Earned_Hrs.Value)</Value>
                  </SortExpression>
                </SortExpressions>
