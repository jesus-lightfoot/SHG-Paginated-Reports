            <Query>
              <Statement>// DAX Query
DEFINE
	VAR __DS0FilterTable = 
		FILTER(
			KEEPFILTERS(VALUES('DimControlDate'[Date])),
			'DimControlDate'[Date] &gt;= DATEVALUE(@ControlDate) &amp;&amp;
			'DimControlDate'[Date] &lt; DATEVALUE(@ControlDate)+ TIME(0,0,1)
		)


	
	VAR __DS0Core = 
		SUMMARIZECOLUMNS('DimProperty'[PropertyName],
			__DS0FilterTable,
