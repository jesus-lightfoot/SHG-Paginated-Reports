              <AutoExecute>false</AutoExecute>
              <From>Model</From>
              <Filter>
                <FilterItems />
              </Filter>
              <Calculations />
              <Aggregates />
              <QueryProperties />
            </QuerySpecification>
            <Query>
              <Statement>// DAX Query
DEFINE
	VAR __DS0FilterTable = 
		FILTER(
			KEEPFILTERS(VALUES('DimControlDate'[d_date])),
			AND(
				'DimControlDate'[d_date] &gt;= DATEVALUE(@ControlDate),
				'DimControlDate'[d_date] &lt; DATEVALUE(@ControlDate) + 1
			)
		)

	VAR __DS0FilterTable2 = 
		FILTER(
			KEEPFILTERS(VALUES('DimProperty'[PropertyName])),
			NOT(ISBLANK('DimProperty'[PropertyName]))
		)
VAR __DS0FilterTable4 = 
		TREATAS({1}, 'DimProperty'[IsActive])

	VAR __DS0Core = 
		SUMMARIZECOLUMNS(
			ROLLUPADDISSUBTOTAL(
				ROLLUPGROUP('DimProperty'[PropertyName], 'DimProperty'[Owner]), "IsGrandTotalRowTotal"
			),
			__DS0FilterTable,
			__DS0FilterTable2,
__DS0FilterTable4,
			"Prior_Day_OCC__", 'Revenue Metrics'[Prior Day OCC %],
			"Prior_Day_ADR", 'Revenue Metrics'[Prior Day ADR],
			"Prior_Day_RevPAR", 'Revenue Metrics'[Prior Day RevPAR],
			"Prior_Day_Occupied_Rooms_Revenue", 'Revenue Metrics'[Prior Day Occupied Rooms Revenue],
			"Fwd_7_Occ__", 'Revenue Metrics'[Fwd 7 Occ %],
			"Fwd_7_RevPAR", 'Revenue Metrics'[Fwd 7 RevPAR],
			"MTD_Occ__", 'Revenue Metrics'[MTD Occ %],
			"MTD_ADR", 'Revenue Metrics'[MTD ADR],
			"MTD_RevPAR", 'Revenue Metrics'[MTD RevPAR],
			"MTD_Occupied_Rooms_Revenue", 'Revenue Metrics'[MTD Occupied Rooms Revenue],
			"Full_Month_Var_To_Budget_Department_Sales", 'Revenue Metrics'[Full Month Var To Budget Department Sales],
			"Fwd_7_Occupied_Rooms_Revenue", 'Revenue Metrics'[Fwd 7 Occupied Rooms Revenue],
			"Prior_Day_Available_Rooms_Cover", 'Revenue Metrics'[Prior Day Available Rooms Cover],
                                                "Made_FCL", 'Revenue Metrics'[Made FCL],
			"Prior_Day_Occupied_Rooms_Cover", 'Revenue Metrics'[Prior Day Occupied Rooms Cover],
			"Fwd_7_ADR", 'Revenue Metrics'[Fwd 7 ADR],
			"Prior_Day_Total_Revenue", 'Revenue Metrics'[Prior Day Total Revenue],
			"Fwd_7_Total_Revenue", 'Revenue Metrics'[Fwd 7 Total Revenue],
			"MTD_Total_Revenue", 'Revenue Metrics'[MTD Total Revenue],
			"Full_Month_Department_Sales_Revenue", 'Revenue Metrics'[Full Month Department Sales Revenue],
			"Prior_Day_Outlet_F_B_Revenue", 'Revenue Metrics'[Prior Day Outlet F&amp;B Revenue],
			"Fwd_7_Day_Outlet_F_B_Revenue", 'Revenue Metrics'[Fwd 7 Day Outlet F&amp;B Revenue],
			"MTD_Outlet_F_B_Revenue", 'Revenue Metrics'[MTD Outlet F&amp;B Revenue],
			"Prior_Day_Restaurant_Outlet_Revenue", 'Revenue Metrics'[Prior Day Restaurant Outlet Revenue],
			"Fwd_7_Total_Restaurant_Outlet_Revenue", 'Revenue Metrics'[Fwd 7 Total Restaurant Outlet Revenue],
			"MTD_Restaurant_Outlet_Revenue", 'Revenue Metrics'[MTD Restaurant Outlet Revenue],
			"Full_Month_Var_To_FCL_Department_Sales", 'Revenue Metrics'[Full Month Var To FCL Department Sales],
                                            "__Variance_From_FCL", IGNORE('Revenue Metrics'[% Variance From FCL]),
"__Variance_From_Budget", IGNORE('Revenue Metrics'[% Variance From Budget]),
			"Delta_Occ__", IGNORE('Revenue Metrics'[Delta Occ %]),
			"Delta_ADR", IGNORE('Revenue Metrics'[Delta ADR]),
			"Delta_RevPAR", IGNORE('Revenue Metrics'[Delta RevPAR]),
			"Delta_Occupied_Room_Revenue", IGNORE('Revenue Metrics'[Delta Occupied Room Revenue]),
			"Delta_Total_Revenue", IGNORE('Revenue Metrics'[Delta Total Revenue]),
			"Delta_Outlet_F_B_Revenue", IGNORE('Revenue Metrics'[Delta Outlet F&amp;B Revenue]),
			"Delta_Restaurant_Outlet_Revenue", IGNORE('Revenue Metrics'[Delta Restaurant Outlet Revenue]),
                                           "Made Var From FCL Count", IGNORE('Revenue Metrics'[Made Variance from FCL Count]),
                                           "Total Months Since Start Of Year", IGNORE('Date Metrics'[Total Months Since Start Of Year - Control])

		)

	VAR __DS0PrimaryWindowed = 
		TOPN(
			502,
			__DS0Core,
			[IsGrandTotalRowTotal],
			0,
			[Prior_Day_OCC__],
			0,
			'DimProperty'[PropertyName],
			1,
			'DimProperty'[Owner],
			1
		)

EVALUATE
	__DS0PrimaryWindowed

ORDER BY
	[IsGrandTotalRowTotal] DESC,
	[Prior_Day_OCC__] DESC,
	'DimProperty'[PropertyName],
	'DimProperty'[Owner]
                </Statement>
              <ParameterDefinitions>
                <ParameterDefinition>
                  <Name>ControlDate</Name>
                  <DefaultValues>
                    <DefaultValue>=DateAdd("d",-1,Today())</DefaultValue>
                  </DefaultValues>
                  <Caption>ControlDate</Caption>
                  <ParameterValuesQuery>
                    <ParameterizedStatement>
                      <ReferencedParameters />
                    </ParameterizedStatement>
                  </ParameterValuesQuery>
                </ParameterDefinition>
              </ParameterDefinitions>
            </Query>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>DEFINE
	// VAR __DS0FilterTable = 
	// 	FILTER(
	// 		KEEPFILTERS(VALUES('DimProperty'[PropertyName])),
	// 		NOT('DimProperty'[PropertyName] IN {BLANK()}) 
	// 	)
	
	VAR __DS0FilterTable =
    FILTER(
        'DimProperty',
        NOT ISBLANK('DimProperty'[PropertyName])
            &amp;&amp; 'DimProperty'[CurrentRecord] = "Y"
    )
	VAR __DS0FilterTable2 = 
		FILTER(
			KEEPFILTERS(VALUES('DimControlDate'[Date])),
			AND(
				'DimControlDate'[Date] &gt;= DATEVALUE(@ControlDate),
				'DimControlDate'[Date] &lt; (DATEVALUE(@ControlDate) + TIME(0, 0, 1))
			)
		)

	VAR __DS0Core = 
		SUMMARIZECOLUMNS(
			ROLLUPADDISSUBTOTAL(
				ROLLUPGROUP('DimProperty'[PropertyName], 'DimProperty'[Owner]), "IsGrandTotalRowTotal"
			),
			__DS0FilterTable,
			__DS0FilterTable2,
			"Full_Month_Var_To_Budget_Department_Sales", 'Revenue Metrics'[Full Month Var To Budget Department Sales],
			"Prior_Day_Total_Revenue", 'Revenue Metrics'[Prior Day Total Revenue],
			"Fwd_7_Total_Revenue", 'Revenue Metrics'[Fwd 7 Total Revenue],
			"MTD_Total_Revenue", 'Revenue Metrics'[MTD Total Revenue],
			"Full_Month_Department_Sales_Revenue", 'Revenue Metrics'[Full Month Department Sales Revenue],
			"Prior_Day_Outlet_F_B_Revenue", 'Revenue Metrics'[Prior Day Outlet F&amp;B Revenue],
			"Fwd_7_Day_Outlet_F_B_Revenue", 'Revenue Metrics'[Fwd 7 Day Outlet F&amp;B Revenue],
			"MTD_Outlet_F_B_Revenue", 'Revenue Metrics'[MTD Outlet F&amp;B Revenue],
			"Prior_Day_Restaurant_Outlet_Revenue", 'Revenue Metrics'[Prior Day Restaurant Outlet Revenue],
			"Fwd_7_Total_Restaurant_Outlet_Revenue", 'Revenue Metrics'[Fwd 7 Total Restaurant Outlet Revenue],
			"MTD_Restaurant_Outlet_Revenue", 'Revenue Metrics'[MTD Restaurant Outlet Revenue],
			"Full_Month_Var_To_FCL_Department_Sales", 'Revenue Metrics'[Full Month Var To FCL Department Sales],
			"v__Variance_From_FCL", 'Revenue Metrics'[% Variance From FCL],
			"Prior_Day_OCC__", 'Occupancy Metrics'[Prior Day OCC %],
			"Prior_Day_ADR", 'Occupancy Metrics'[Prior Day ADR],
			"Prior_Day_Occupied_Rooms_Revenue", 'Occupancy Metrics'[Prior Day Occupied Rooms Revenue],
			"Fwd_7_Occ__", 'Occupancy Metrics'[Fwd 7 Occ %],
			"Fwd_7_ADR", 'Occupancy Metrics'[Fwd 7 ADR],
			"Fwd_7_Occupied_Rooms_Revenue", 'Occupancy Metrics'[Fwd 7 Occupied Rooms Revenue],
			"Fwd_7_RevPAR", 'Occupancy Metrics'[Fwd 7 RevPAR],
			"MTD_Occ__", 'Occupancy Metrics'[MTD Occ %],
			"MTD_Occupied_Rooms_Revenue", 'Occupancy Metrics'[MTD Occupied Rooms Revenue],
			"MTD_RevPAR", 'Occupancy Metrics'[MTD RevPAR],
			"MTD_ADR", 'Occupancy Metrics'[MTD ADR],
			"Prior_Day_RevPAR", 'Occupancy Metrics'[Prior Day RevPAR],
			"Prior_Day_Available_Room_Nights", 'Occupancy Metrics'[Prior Day Available Room Nights],
			"Prior_Day_Occupied_Room_Nights", 'Occupancy Metrics'[Prior Day Occupied Room Nights],
			"Made_FCL", 'Revenue Metrics'[Made FCL],
			"v__Variance_From_Budget", 'Revenue Metrics'[% Variance From Budget],
			"Delta_Total_Revenue", IGNORE('Revenue Metrics'[Delta Total Revenue]),
			"Delta_Outlet_F_B_Revenue", IGNORE('Revenue Metrics'[Delta Outlet F&amp;B Revenue]),
			"Delta_Restaurant_Outlet_Revenue", IGNORE('Revenue Metrics'[Delta Restaurant Outlet Revenue]),
			"Delta_Occ__", IGNORE('Occupancy Metrics'[Delta Occ %]),
			"Delta_ADR", IGNORE('Occupancy Metrics'[Delta ADR]),
			"Delta_RevPAR", IGNORE('Occupancy Metrics'[Delta RevPAR]),
			"Made Var From FCL Count", IGNORE('Revenue Metrics'[Made Variance from FCL Count]),
             "Total Months Since Start Of Year", IGNORE('Date Metrics'[Total Months Since Start Of Year - Control])
		)

	VAR __DS0PrimaryWindowed = 
		TOPN(
			502,
			__DS0Core,
			[IsGrandTotalRowTotal],
			0,
			[Full_Month_Var_To_Budget_Department_Sales],
			1,
			'DimProperty'[PropertyName],
			1,
			'DimProperty'[Owner],
			1
		)

EVALUATE
	__DS0PrimaryWindowed

ORDER BY
	[IsGrandTotalRowTotal] DESC,
	[Full_Month_Var_To_Budget_Department_Sales],
	'DimProperty'[PropertyName],
	'DimProperty'[Owner]</CommandText>
      </Query>
      <Fields>
        <Field Name="PropertyName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DimProperty[PropertyName]</DataField>
        </Field>
        <Field Name="Owner">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DimProperty[Owner]</DataField>
        </Field>
        <Field Name="Prior_Day_OCC__">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Prior_Day_OCC__]</DataField>
        </Field>
        <Field Name="Prior_Day_ADR">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Prior_Day_ADR]</DataField>
        </Field>
        <Field Name="Prior_Day_RevPAR">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Prior_Day_RevPAR]</DataField>
        </Field>
        <Field Name="Prior_Day_Occupied_Rooms_Revenue">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Prior_Day_Occupied_Rooms_Revenue]</DataField>
        </Field>
        <Field Name="Fwd_7_Occ__">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Fwd_7_Occ__]</DataField>
        </Field>
        <Field Name="Fwd_7_RevPAR">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Fwd_7_RevPAR]</DataField>
        </Field>
        <Field Name="MTD_Occ__">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[MTD_Occ__]</DataField>
        </Field>
        <Field Name="MTD_ADR">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[MTD_ADR]</DataField>
        </Field>
        <Field Name="MTD_RevPAR">
          <rd:TypeName>System.String</rd:TypeName>
