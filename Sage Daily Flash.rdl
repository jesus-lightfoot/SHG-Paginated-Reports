    <DataSet Name="NarrativeData">
      <Query>
        <DataSourceName>SHGDev_SHGWarehouse04Sandbox</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="ControlDate">
            <Value>=Format(Parameters!ControlDate.Value, "yyyy-MM-dd")</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>EVALUATE
TOPN(1,
CALCULATETABLE(
	FactDailyNarrative,
	DimDate[Date] = DATEVALUE(@ControlDate) --DATEVALUE("2/8/2026")
)
, FactDailyNarrative[FactDailyNarrativeID], desc)

</CommandText>
      </Query>
      <Fields>
        <Field Name="FactDailyNarrativeID">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>FactDailyNarrative[FactDailyNarrativeID]</DataField>
        </Field>
        <Field Name="DimDateKey">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>FactDailyNarrative[DimDateKey]</DataField>
        </Field>
        <Field Name="DailyNarrative">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>FactDailyNarrative[Narrative]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="P1Graph">
      <Query>
        <DataSourceName>SHGDev_SHGWarehouse04Sandbox</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="ControlDate">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Format(Parameters!ControlDate.Value, "yyyy-MM-dd")</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>EVALUATE
CALCULATETABLE (
    UNION (
        ROW ("SortOrder",5,
            "Category", "Total Revenue (Actual + Forecast)",
            "Amount", BLANK()
			,"Total",'Revenue Metrics'[Full Month Department Sales Revenue]
			
        ),
        ROW ("SortOrder",3,
            "Category", "F&amp;B Revenue Variance To FCL",
            "Amount", 'Revenue Metrics'[Full Month Total F&amp;B Revenue Var To FCL]
			,"Total",BLANK()
        ),
        ROW ("SortOrder",2,
            "Category", "Rooms Revenue Variance To FCL",
            "Amount", 'Revenue Metrics'[Full Month Total Rooms Revenue Var To FCL]
			,"Total",BLANK()
        ),
        ROW ("SortOrder",1,
            "Category", "Total FCL Revenue",
            "Amount", 'Revenue Metrics'[Full Month Department Sales FCL Revenue]
			,"Total",BLANK()
        ),
        ROW ("SortOrder",4,
            "Category", "Other Revenue Variance To FCL",
            "Amount", 'Revenue Metrics'[Full Month Total Other Revenue Var To FCL Plug]
			,"Total",BLANK()
        ),
        ROW ("SortOrder",6,
            "Category", "Full_Month_Total_F_B_Revenue_Var_To_Budget",
            "Amount", 'Revenue Metrics'[Full Month Total F&amp;B Revenue Var To Budget]
			,"Total",BLANK()
        ),
        ROW ("SortOrder",7,
            "Category", "Full_Month_Total_Other_Revenue_Var_To_Budget",
            "Amount", 'Revenue Metrics'[Full Month Total Other Revenue Var To Budget]
			,"Total",BLANK()
        ),
        ROW ("SortOrder",8,
            "Category", "Full_Month_Total_Rooms_Revenue_Var_To_Budget",
            "Amount", 'Revenue Metrics'[Full Month Total Rooms Revenue Var To Budget]
			,"Total",BLANK()
        ),
        ROW ("SortOrder",9,
            "Category", "Full_Month_Department_Sales_Budget_Revenue",
            "Amount", BLANK()
			,"Total",'Revenue Metrics'[Full Month Department Sales Budget Revenue]
        )
    ),
    DimControlDate[Date] = DATEVALUE ( @ControlDate)
)</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_SortOrder_">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>[SortOrder]</DataField>
        </Field>
        <Field Name="ID_Category_">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Category]</DataField>
        </Field>
        <Field Name="ID_Amount_">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>[Amount]</DataField>
        </Field>
        <Field Name="ID_Total_">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>[Total]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="P1GraphRolling">
      <Query>
        <DataSourceName>SHGDev_SHGWarehouse04Sandbox</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="ControlDateParam">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!ControlDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>DEFINE

	VAR _ControlDateParam = DATEVALUE(@ControlDateParam)--DATEVALUE("2/6/2026")
	VAR __DS0FilterTable =
		FILTER(
			KEEPFILTERS(VALUES('DimControlDate'[Date])),
			'DimControlDate'[Date] = _ControlDateParam
			)

	VAR _FlatVal =
	SUMMARIZECOLUMNS('FactRevenueMonthly',
			__DS0FilterTable,
"Full_Month_Total_Budget_Revenue", CALCULATE('Revenue Metrics'[Budget Monthly Revenue], DimRevenue[RevenueCategoryLevel2] = "Total Revenue")


)

VAR _FlatVal2 =
	SUMMARIZECOLUMNS('FactRevenue',
			__DS0FilterTable,
"Full_Month_LY_Total_Revenue", CALCULATE('Revenue Metrics'[Last Year Full Month Revenue], DimRevenue[RevenueCategoryLevel2] = "Total Revenue")


)

	VAR __DS0Core = 
		SUMMARIZECOLUMNS(
			ROLLUPADDISSUBTOTAL('DimDate'[Date], "IsGrandTotalRowTotal"),
			__DS0FilterTable,
			"Rolling_Monthly_Total_Revenue", [Rolling Monthly Total Revenue],
			"Rolling_Monthy_Total_FC_Revenue",[Rolling Monthly Total FC Revenue],
"MTD_Rolling_Total_FCL_Revenue", 'Revenue Metrics'[Rolling Monthly Total FCL Revenue]
// ,"LY_Full_Month_Total_Revenue", [Last Year Full Month Revenue]


		)
	VAR _Cross = 
		CROSSJOIN(__DS0Core,_FlatVal, _FlatVal2)
EVALUATE
	_Cross
	ORDER by DimDate[Date] asc</CommandText>
      </Query>
      <Fields>
        <Field Name="DimDate_Date_">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>DimDate[Date]</DataField>
        </Field>
        <Field Name="ID_Rolling_Monthly_Total_Revenue_">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>[Rolling_Monthly_Total_Revenue]</DataField>
        </Field>
        <Field Name="ID_IsGrandTotalRowTotal_">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>[IsGrandTotalRowTotal]</DataField>
        </Field>
        <Field Name="ID_Rolling_Monthy_Total_FC_Revenue_">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>[Rolling_Monthy_Total_FC_Revenue]</DataField>
        </Field>
        <Field Name="ID_MTD_Rolling_Total_FCL_Revenue_">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>[MTD_Rolling_Total_FCL_Revenue]</DataField>
        </Field>
        <Field Name="ID_Full_Month_Total_Budget_Revenue_">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>[Full_Month_Total_Budget_Revenue]</DataField>
        </Field>
        <Field Name="ID_Full_Month_LY_Total_Revenue_">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>[Full_Month_LY_Total_Revenue]</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
