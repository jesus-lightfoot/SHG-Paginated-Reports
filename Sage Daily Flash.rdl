		SELECTCOLUMNS(
			KEEPFILTERS(FILTER(KEEPFILTERS(__DS0Core), [IsDM1Total] = TRUE)),
			"IsGrandTotalRowTotal", [IsGrandTotalRowTotal],
			"'DimProperty'[DivisionName]", 'DimProperty'[DivisionName],
