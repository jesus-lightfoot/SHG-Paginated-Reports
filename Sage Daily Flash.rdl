			"MTD_Forecast_Accuracy", 'HEAPLabor Metrics'[MTD Forecast Accuracy],
			"WTD_Forecast_Volume_Entry", 'HECompliance Metrics'[WTD Forecast Volume Entry]
		)

EVALUATE
	__DS0Core</CommandText>
      </Query>
